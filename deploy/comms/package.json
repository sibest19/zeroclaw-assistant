{
  "name": "zeroclaw-comms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Message archive comms + MCP server for the ZeroClaw personal assistant (Option C). Keeps ZeroClaw vanilla; ingests WhatsApp + email into a dedicated SQLite archive and exposes it over MCP.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ingest": "tsx src/index.ts",
    "mcp": "tsx src/mcp-standalone.ts",
    "backfill": "tsx src/backfill.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@whiskeysockets/baileys": "^6.7.16",
    "better-sqlite3": "^12.10.0",
    "express": "^5.2.1",
    "imapflow": "^1.4.0",
    "mailparser": "^3.9.9",
    "nodemailer": "^8.0.11",
    "pino": "^9.5.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode-terminal": "^0.12.2",
    "prettier": "^3.8.4",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0"
  }
}
