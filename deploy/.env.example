# Secret iniettati come env-override di ZeroClaw.
# Grammatica: ZEROCLAW_<path_schema_con_doppio_underscore>=valore
# I valori passati così NON vengono mai scritti su disco (a differenza dei secret
# messi nel config.toml, che verrebbero cifrati e salvati).
#
# Uso:
#   cp .env.example .env      # poi riempi i valori reali (.env NON va committato)
#   docker compose up -d      # docker compose carica automaticamente ./.env

# ── Telegram (canale di controllo) ──────────────────────────────────────────
ZEROCLAW_channels__telegram__default__bot_token=

# ── Trascrizione vocali (Groq Whisper) ──────────────────────────────────────
ZEROCLAW_providers__transcription__groq__default__api_key=

# ── Gmail × 3 (app password, NON la password normale) ───────────────────────
ZEROCLAW_channels__email__gmail_personal__password=
ZEROCLAW_channels__email__gmail_work__password=
ZEROCLAW_channels__email__gmail_cloud__password=

# ── Codex: NON serve qui (usa auth profile via `zeroclaw auth`, non una api_key) ─

# ── Solo per TEST LOCALE: esponi il gateway dentro il container ──────────────
# (necessario se vuoi raggiungere la dashboard dall'host; per il solo Telegram
#  in long-polling non serve)
# ZEROCLAW_BIND=0.0.0.0
