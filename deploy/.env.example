# Secret per lo stack. Copia in .env (NON committato) e riempi.
#   cp .env.example .env
#   ./setup-zc-data.sh && docker compose up -d

# ── ZeroClaw (container 'zeroclaw') ─────────────────────────────────────────
# Env-override di ZeroClaw: ZEROCLAW_<path__con__doppio_underscore>=valore.
# Il bot token Telegram da @BotFather.
ZEROCLAW_channels__telegram__default__bot_token=
# Codex: NON serve qui (usa l'auth profile in zc-data, via `zeroclaw auth login`).

# ── comms (container 'comms') — Email IMAP/SMTP, on-demand ──────────────────
# Account Gmail (app password, NON la password normale). imap/smtp default a Gmail.
# JSON su UNA riga:
EMAIL_ACCOUNTS_JSON=[{"name":"personal","user":"tu.personale@gmail.com","pass":"APP_PASSWORD_1"},{"name":"work","user":"tu.lavoro@gmail.com","pass":"APP_PASSWORD_2"},{"name":"cloud","user":"tu.cloud@gmail.com","pass":"APP_PASSWORD_3"}]
# Opzionali: EMAIL_BACKFILL_DAYS=180  EMAIL_POLL_SECS=180

# ── Solo TEST LOCALE: esponi il gateway ZeroClaw nel container (dashboard) ──
# ZEROCLAW_BIND=0.0.0.0
