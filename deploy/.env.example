# Secret per lo stack. Copia in .env (NON committato) e riempi.
#   cp .env.example .env
#   ./setup-zc-data.sh && docker compose up -d

# ── ZeroClaw (container 'zeroclaw') ─────────────────────────────────────────
# Env-override di ZeroClaw: ZEROCLAW_<path__con__doppio_underscore>=valore.
# Il bot token Telegram da @BotFather.
ZEROCLAW_channels__telegram__default__bot_token=
# Codex: NON serve qui (usa l'auth profile in zc-data, via `zeroclaw auth login`).

# ── comms (container 'comms') — Email IMAP/SMTP, on-demand ──────────────────
# Multi-provider: ogni account usa una app password (NON la password normale).
# imap/smtp default a Gmail; per altri provider (iCloud, ecc.) passa imap_host/
# imap_port/smtp_host/smtp_port. iCloud: usa gli host UFFICIALI imap.mail.me.com:993 /
# smtp.mail.me.com:587 (gli alias *.icloud.com NON sono raggiungibili da tutte le reti).
# App password su appleid.apple.com. Lo username resta l'indirizzo completo @icloud.com.
# email_cerca espone criteri STRUTTURATI uguali per ogni provider (mittente/destinatario/
# oggetto/testo/dopo/prima); con_allegati funziona solo su Gmail. Comms traduce in
# X-GM-RAW su Gmail e IMAP SEARCH standard altrove.
# JSON su UNA riga:
EMAIL_ACCOUNTS_JSON=[{"name":"personal","user":"tu.personale@gmail.com","pass":"APP_PASSWORD_1"},{"name":"work","user":"tu.lavoro@gmail.com","pass":"APP_PASSWORD_2"},{"name":"cloud","user":"tu.cloud@icloud.com","pass":"APP_PASSWORD_3","imap_host":"imap.mail.me.com","imap_port":993,"smtp_host":"smtp.mail.me.com","smtp_port":587}]
# Opzionali: EMAIL_BACKFILL_DAYS=180  EMAIL_POLL_SECS=180

# ── Solo TEST LOCALE: esponi il gateway ZeroClaw nel container (dashboard) ──
# ZEROCLAW_BIND=0.0.0.0
